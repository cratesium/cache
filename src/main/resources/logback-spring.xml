<?xml version="1.0" encoding="UTF-8"?>
<!--
  logback-spring.xml
  ══════════════════
  Spring Boot picks this up automatically (preferred over logback.xml
  because it supports Spring's <springProperty> and <springProfile> features).

  Log format includes:
    - ISO-8601 timestamp
    - Log level (padded to 5 chars)
    - Auto-generated requestId from MDC  (%X{requestId} — populated by RequestLoggingInterceptor)
    - Thread name
    - Logger name (abbreviated)
    - Message

  Two appenders:
    1. CONSOLE — human-readable coloured output for local dev
    2. FILE    — JSON-like structured output for production log aggregation
-->
<configuration scan="true" scanPeriod="30 seconds">

    <!-- ── Pull values from application.properties ───────────────────────── -->
    <springProperty scope="context" name="appName"  source="spring.application.name" defaultValue="app"/>
    <springProperty scope="context" name="logLevel" source="logging.level.root"      defaultValue="INFO"/>

    <!-- ── Console Appender (dev-friendly, coloured) ─────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p) %clr([${appName}]){cyan} %clr([%X{requestId:-NO_REQ_ID}]){yellow} %clr([%t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n%wEx
            </pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ── Rolling File Appender (structured, rotation by day + size) ────── -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/${appName}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Roll daily and when file exceeds 50 MB -->
            <fileNamePattern>logs/${appName}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <!-- Keep 30 days of history -->
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <!-- Structured log line (easy for Loki / ELK ingestion) -->
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [${appName}] [requestId=%X{requestId:-}] [%t] %-40.40logger{39} : %m%n%ex
            </pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ── Async wrapper for FILE appender (non-blocking I/O) ────────────── -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold>
        <queueSize>512</queueSize>
        <appender-ref ref="FILE"/>
    </appender>

    <!-- ── Logger overrides ───────────────────────────────────────────────── -->
    <!-- Reduce noise from framework internals -->
    <logger name="org.springframework.security"         level="WARN"/>
    <logger name="org.springframework.web"              level="INFO"/>
    <logger name="org.springframework.kafka"            level="INFO"/>
    <logger name="org.springframework.data.redis"       level="INFO"/>
    <logger name="org.hibernate.SQL"                    level="DEBUG"/>
    <logger name="org.hibernate.orm.jdbc.bind"          level="TRACE"/>

    <!-- Our application code at DEBUG during dev, INFO in prod -->
    <logger name="com.kafka.shikhar.app"                level="DEBUG"/>

    <!-- ── Root logger ────────────────────────────────────────────────────── -->
    <root level="${logLevel}">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </root>

    <!-- ── Dev profile: only CONSOLE, DEBUG for everything ──────────────── -->
    <springProfile name="dev">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ── Prod profile: no console, INFO for root ───────────────────────── -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="ASYNC_FILE"/>
        </root>
    </springProfile>

</configuration>
